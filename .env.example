# CampusQuant 环境变量模板
# 复制为 .env 并填写真实值

# ── 必填 ──
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_MODEL_NAME=qwen3.5-plus

# ── 数据库 ──
DATABASE_URL=mysql+asyncmy://user:password@localhost/campusquant?charset=utf8mb4

# ── 可选: OpenAI 兼容代理 ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── 可选: 邮件 ──
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CampusQuant
SMTP_USE_SSL=true

# ── 内地数据中继 ──
INLAND_RELAY_BASE_URL=http://47.108.191.110:8001
INLAND_RELAY_TOKEN=your-relay-token

# ── JWT ──
JWT_SECRET_KEY=change-me-to-random-string

# ── 静态文件(开发模式) ──
SERVE_STATIC=true
